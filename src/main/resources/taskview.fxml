<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmanager.controller.TaskController"
      spacing="12"
      styleClass="root-container"
      style="-fx-padding: 20;">

    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Smart Task Manager"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #00b4d8;"/>
        <Button fx:id="themeToggleBtn" text="☀ Light Mode" onAction="#handleThemeToggle"
                style="-fx-background-color: #1a1a2e; -fx-text-fill: #00b4d8; -fx-padding: 6 14; -fx-background-radius: 20; -fx-cursor: hand; -fx-border-color: #00b4d8; -fx-border-radius: 20;"/>
    </HBox>

    <HBox spacing="16">
        <Label fx:id="totalLabel" text="Total: 0" styleClass="stat-label"/>
        <Label fx:id="inProgressLabel" text="In Progress: 0" styleClass="stat-label-warning"/>
        <Label fx:id="doneLabel" text="Done: 0" styleClass="stat-label-success"/>
    </HBox>

    <TextField fx:id="searchField" promptText="🔍 Search tasks..."
               styleClass="search-field"
               prefWidth="400"/>

    <HBox spacing="10">
        <TextField fx:id="titleField" promptText="Task title..."
                   styleClass="input-field"
                   prefWidth="220"/>
        <ComboBox fx:id="priorityBox" promptText="Priority" prefWidth="110"
                  style="-fx-background-color: #1a1a2e; -fx-text-fill: #fff; -fx-border-color: #333; -fx-border-radius: 8;"/>
        <ComboBox fx:id="statusBox" promptText="Status" prefWidth="120"
                  style="-fx-background-color: #1a1a2e; -fx-text-fill: #fff; -fx-border-color: #333; -fx-border-radius: 8;"/>
        <TextField fx:id="dueDateField" promptText="Due date (e.g. 2025-06-01)"
                   styleClass="input-field"
                   prefWidth="160"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Add Task" onAction="#handleAddTask"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="Edit Task" onAction="#handleEditTask"
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="Delete Task" onAction="#handleDeleteTask"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="statusLabel" text=""
           style="-fx-text-fill: #00b4d8; -fx-font-size: 12;"/>

    <TableView fx:id="taskTable" prefHeight="380"
               styleClass="task-table">
        <columns>
            <TableColumn fx:id="titleCol" text="Task Title" prefWidth="280"/>
            <TableColumn fx:id="priorityCol" text="Priority" prefWidth="100"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
            <TableColumn fx:id="dueDateCol" text="Due Date" prefWidth="130"/>
        </columns>
    </TableView>

</VBox>